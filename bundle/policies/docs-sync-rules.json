  "sync_rules": {
    "timing": {
      "same_pr_sync": "When a canonical source is modified, each required derived surface must be updated in the same pull request unless an approved docs:needs-sync deferral and follow-up task contract are recorded.",
      "follow_up_tolerance": "Follow-up sync work must be traceable and completed under DOCUMENTATION_POLICY.md timing requirements.",
      "maximum_drift_age": "Drift older than the tolerance defined in DOCUMENTATION_POLICY.md is a compliance violation."
    },
    "tolerance": {
      "formatting_differences": "Minor formatting differences are acceptable when they do not alter meaning. Wiki-specific navigation is permitted.",
      "content_divergence": "Derived pages must not contradict their canonical sources.",
      "addition_policy": "Derived surfaces may add navigation and cross-references but must not introduce new binding requirements."
    },
    "format": {
      "canonical_format": "GitHub-flavored Markdown or JSON",
      "derived_wiki_format": "GitHub Wiki Markdown",
      "json_to_markdown_rendering": "When a canonical source is JSON, the derived markdown must summarize current fields, values, and relationships without contradiction."
    }
  },
  "pre_merge_gates": [
    {
      "gate_id": "docs-sync-path-existence",
      "compliance_rule_id": "FAE-C008",
      "validator_mode": "docs",
      "inputs": ["sync_pairs"],
      "evidence_required": ["canonical path exists", "derived path exists"],
      "rejection_condition": "sync_pair_references_missing_path",
      "failure_status": "request_changes"
    },
    {
      "gate_id": "docs-sync-changed-source",
      "compliance_rule_id": "FAE-C008",
      "validator_mode": "contract",
      "inputs": ["task_contract", "changed_files", "sync_pairs"],
      "evidence_required": ["changed canonical source", "changed derived page or approved deferral"],
      "rejection_condition": "canonical_changed_without_required_derived_sync",
      "failure_status": "request_changes"
    },
    {
      "gate_id": "docs-sync-structure",
      "compliance_rule_id": "FAE-C011",
      "validator_mode": "policies",
      "inputs": ["sync_pairs"],
      "evidence_required": ["rule_id", "trigger_paths", "required_derived_paths", "evidence_required", "rejection_condition"],
      "rejection_condition": "docs_sync_rule_missing_enforceable_fields",
      "failure_status": "block"
    }
  ],
  "review_requirements": {
    "who_reviews": "documentation_manager",
    "review_scope": [
      "Verify modified canonical sources have corresponding derived surface updates or documented follow-up tracking.",
      "Verify derived wiki pages do not contradict canonical sources.",
      "Verify wiki-specific additions are limited to navigation, orientation, and cross-reference aids.",
      "Verify JSON-to-markdown derived documents accurately summarize the current JSON canonical source.",
      "Flag stale or missing paths as documentation drift.",
      "Verify every sync pair includes a stable rule_id, evidence requirement, and rejection condition."
    ],
    "review_timing": "Documentation sync review must occur before the validator renders a final compliance decision on any change that modifies canonical sources.",
    "escalation": "If widespread drift is detected across multiple sync pairs, the documentation_manager must escalate to the architect for a dedicated documentation sync task contract."
  }
}
