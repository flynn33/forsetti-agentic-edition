{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forsetti.dev/ffae/evidence-bundle.schema.json",
  "title": "FFAE Completion Evidence Bundle",
  "type": "object",
  "required": [
    "schemaVersion",
    "bundleID",
    "taskID",
    "projectID",
    "productLockHash",
    "policyLockHash",
    "profileLockHash",
    "contractHash",
    "changedFilesHash",
    "validationResults",
    "commandEvidence",
    "roleLedgerPath",
    "knownIssues",
    "finalDecision",
    "createdAtUTC"
  ],
  "properties": {
    "schemaVersion": {
      "const": "2.0"
    },
    "bundleID": {
      "type": "string",
      "minLength": 1
    },
    "taskID": {
      "type": "string",
      "pattern": "^[A-Z0-9][A-Z0-9._-]{2,127}$"
    },
    "projectID": {
      "type": "string",
      "minLength": 1
    },
    "productLockHash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "policyLockHash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "profileLockHash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "contractHash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "changedFilesHash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "validationResults": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "mode",
          "path",
          "sha256",
          "status"
        ],
        "properties": {
          "mode": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "status": {
            "enum": [
              "pass",
              "request_changes",
              "block"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "commandEvidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "roleLedgerPath": {
      "type": "string",
      "minLength": 1
    },
    "knownIssues": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "skippedChecks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "check",
          "rationale",
          "decision"
        ],
        "properties": {
          "check": {
            "type": "string",
            "minLength": 1
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          },
          "decision": {
            "enum": [
              "request_changes",
              "block"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "finalDecision": {
      "enum": [
        "pass",
        "request_changes",
        "block"
      ]
    },
    "createdAtUTC": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
