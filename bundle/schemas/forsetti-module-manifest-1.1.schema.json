{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forsetti.dev/ffae/forsetti-module-manifest-1.1.schema.json",
  "title": "Forsetti Module Manifest 1.1",
  "type": "object",
  "required": [
    "schemaVersion",
    "manifestTemplateVersion",
    "moduleID",
    "displayName",
    "moduleVersion",
    "moduleType",
    "supportedPlatforms",
    "minForsettiVersion",
    "capabilitiesRequested",
    "entryPoint",
    "runtimeRequirements"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.1"
    },
    "manifestTemplateVersion": {
      "const": "1.1"
    },
    "moduleID": {
      "type": "string",
      "pattern": "^[A-Za-z0-9]+(?:[.-][A-Za-z0-9_-]+)+$"
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "moduleVersion": {
      "type": "object",
      "required": [
        "major",
        "minor",
        "patch"
      ],
      "properties": {
        "major": {
          "type": "integer",
          "minimum": 0
        },
        "minor": {
          "type": "integer",
          "minimum": 0
        },
        "patch": {
          "type": "integer",
          "minimum": 0
        },
        "prerelease": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "moduleType": {
      "enum": [
        "service",
        "ui",
        "app"
      ]
    },
    "supportedPlatforms": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "iOS",
          "macOS",
          "Windows"
        ]
      }
    },
    "minForsettiVersion": {
      "type": "object",
      "required": [
        "major",
        "minor",
        "patch"
      ],
      "properties": {
        "major": {
          "type": "integer",
          "minimum": 0
        },
        "minor": {
          "type": "integer",
          "minimum": 0
        },
        "patch": {
          "type": "integer",
          "minimum": 0
        },
        "prerelease": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "maxForsettiVersion": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "major",
            "minor",
            "patch"
          ],
          "properties": {
            "major": {
              "type": "integer",
              "minimum": 0
            },
            "minor": {
              "type": "integer",
              "minimum": 0
            },
            "patch": {
              "type": "integer",
              "minimum": 0
            },
            "prerelease": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "additionalProperties": false
        },
        {
          "type": "null"
        }
      ]
    },
    "capabilitiesRequested": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "iapProductID": {
      "type": [
        "string",
        "null"
      ]
    },
    "entryPoint": {
      "type": "string",
      "minLength": 1
    },
    "defaultModuleRole": {
      "enum": [
        "ui",
        "shared_database",
        "authentication",
        "diagnostics",
        "api",
        "security",
        null
      ]
    },
    "runtimeRequirements": {
      "type": "object",
      "required": [
        "io",
        "ui",
        "dataIsolation"
      ],
      "properties": {
        "io": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ioRequirement"
          }
        },
        "ui": {
          "oneOf": [
            {
              "$ref": "#/$defs/uiRequirement"
            },
            {
              "type": "null"
            }
          ]
        },
        "dataIsolation": {
          "$ref": "#/$defs/dataIsolation"
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "ioRequirement": {
      "type": "object",
      "required": [
        "requirementID",
        "kind",
        "access",
        "required"
      ],
      "properties": {
        "requirementID": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "enum": [
            "networking",
            "storage",
            "secure_storage",
            "file_export",
            "crypto_utilities",
            "telemetry",
            "shared_database",
            "authentication",
            "diagnostics",
            "api",
            "security"
          ]
        },
        "access": {
          "enum": [
            "read",
            "write",
            "read_write",
            "execute",
            "emit",
            "consume"
          ]
        },
        "required": {
          "type": "boolean"
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "uiRequirement": {
      "type": "object",
      "properties": {
        "controlSchemeID": {
          "type": [
            "string",
            "null"
          ]
        },
        "layoutID": {
          "type": [
            "string",
            "null"
          ]
        },
        "themeIDs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "viewIDs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "slotIDs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "toolbarItemIDs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "routeIDs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "pointerIDs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "dataIsolation": {
      "type": "object",
      "required": [
        "mode",
        "ownedStoreIDs",
        "requiredDefaultRoles"
      ],
      "properties": {
        "mode": {
          "enum": [
            "private_to_module",
            "framework_mediated_shared"
          ]
        },
        "ownedStoreIDs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "requiredDefaultRoles": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": [
              "ui",
              "shared_database",
              "authentication",
              "diagnostics",
              "api",
              "security"
            ]
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
