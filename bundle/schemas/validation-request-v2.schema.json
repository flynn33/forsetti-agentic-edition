{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forsetti.dev/ffae/validation-request-v2.schema.json",
  "title": "FFAE Validation Request v2",
  "type": "object",
  "required": [
    "schemaVersion",
    "mode",
    "repositoryRoot",
    "productBundleRoot"
  ],
  "properties": {
    "schemaVersion": {
      "const": "2.0"
    },
    "mode": {
      "enum": [
        "self",
        "project",
        "module",
        "task-check",
        "task-complete",
        "evidence",
        "fixture"
      ]
    },
    "repositoryRoot": {
      "type": "string",
      "minLength": 1
    },
    "productBundleRoot": {
      "type": "string",
      "minLength": 1
    },
    "taskID": {
      "type": [
        "string",
        "null"
      ]
    },
    "moduleIDs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "outputPath": {
      "type": [
        "string",
        "null"
      ]
    },
    "strict": {
      "type": "boolean",
      "default": true
    }
  },
  "additionalProperties": false
}
