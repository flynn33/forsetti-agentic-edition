{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forsetti.dev/ffae/fixture-expectation.schema.json",
  "title": "FFAE Fixture Expectation",
  "type": "object",
  "required": [
    "schemaVersion",
    "fixtureID",
    "platforms",
    "command",
    "expectedStatus",
    "requiredRuleIDs",
    "forbiddenRuleIDs"
  ],
  "properties": {
    "schemaVersion": {
      "const": "2.0"
    },
    "fixtureID": {
      "type": "string",
      "minLength": 1
    },
    "platforms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "apple-host",
          "windows-host"
        ]
      }
    },
    "command": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "expectedStatus": {
      "enum": [
        "pass",
        "request_changes",
        "block"
      ]
    },
    "requiredRuleIDs": {
      "type": "array",
      "items": {
        "pattern": "^FAE-[CF]\\d{3}$"
      }
    },
    "forbiddenRuleIDs": {
      "type": "array",
      "items": {
        "pattern": "^FAE-[CF]\\d{3}$"
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
