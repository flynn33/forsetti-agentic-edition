{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forsetti.dev/ffae/role-ledger.schema.json",
  "title": "FFAE Role Execution Ledger",
  "type": "object",
  "required": [
    "schemaVersion",
    "taskID",
    "accountableOwner",
    "implementationSessionID",
    "validationSessionID",
    "changedFilesHashAtHandoff",
    "validatorModifiedImplementation",
    "reviewDecision",
    "recordedAtUTC"
  ],
  "properties": {
    "schemaVersion": {
      "const": "2.0"
    },
    "taskID": {
      "type": "string",
      "pattern": "^[A-Z0-9][A-Z0-9._-]{2,127}$"
    },
    "accountableOwner": {
      "type": "string",
      "minLength": 1
    },
    "implementationSessionID": {
      "type": "string",
      "minLength": 1
    },
    "validationSessionID": {
      "type": "string",
      "minLength": 1
    },
    "changedFilesHashAtHandoff": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "validatorModifiedImplementation": {
      "type": "boolean"
    },
    "reviewDecision": {
      "enum": [
        "pass",
        "request_changes",
        "block"
      ]
    },
    "recordedAtUTC": {
      "type": "string",
      "format": "date-time"
    },
    "reviewEvidencePath": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false
}
