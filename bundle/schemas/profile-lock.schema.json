{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forsetti.dev/ffae/profile-lock.schema.json",
  "title": "Forsetti Edition Profile Lock",
  "type": "object",
  "required": [
    "schemaVersion",
    "lockedAtUTC",
    "sha256",
    "profileID",
    "profileVersion",
    "frameworkVersion",
    "sourceRevision",
    "supportStatus"
  ],
  "properties": {
    "schemaVersion": {
      "const": "2.0"
    },
    "lockedAtUTC": {
      "type": "string",
      "format": "date-time"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "profileID": {
      "type": "string",
      "minLength": 1
    },
    "profileVersion": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    },
    "frameworkVersion": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    },
    "sourceRevision": {
      "type": "string",
      "minLength": 1
    },
    "supportStatus": {
      "enum": [
        "supported",
        "deprecated",
        "unsupported"
      ]
    }
  },
  "additionalProperties": false
}
