{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forsetti.dev/ffae/project.schema.json",
  "title": "Forsetti Governed Project",
  "type": "object",
  "required": [
    "schemaVersion",
    "projectID",
    "repositoryType",
    "edition",
    "targetPlatforms",
    "frameworkVersion",
    "deploymentPattern",
    "modulesPath",
    "profileLockPath",
    "policyLockPath",
    "productLockPath"
  ],
  "properties": {
    "schemaVersion": {
      "const": "2.0"
    },
    "projectID": {
      "type": "string",
      "minLength": 3
    },
    "repositoryType": {
      "enum": [
        "application_repository",
        "module_repository",
        "sample_repository",
        "governance_product_repository"
      ]
    },
    "edition": {
      "enum": [
        "apple",
        "windows",
        "self"
      ]
    },
    "targetPlatforms": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "iOS",
          "macOS",
          "Windows",
          "self"
        ]
      }
    },
    "frameworkVersion": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    },
    "deploymentPattern": {
      "enum": [
        "single_app_module",
        "multi_module_single_app",
        "developer_testing",
        "dashboard",
        "standalone_module",
        "governance_product"
      ]
    },
    "modulesPath": {
      "type": "string",
      "minLength": 1
    },
    "profileLockPath": {
      "type": "string",
      "minLength": 1
    },
    "policyLockPath": {
      "type": "string",
      "minLength": 1
    },
    "productLockPath": {
      "type": "string",
      "minLength": 1
    },
    "initializedAtUTC": {
      "type": "string",
      "format": "date-time"
    },
    "initializedByVersion": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "repositoryType": {
            "enum": [
              "application_repository",
              "module_repository",
              "sample_repository"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "edition": {
            "enum": [
              "apple",
              "windows"
            ]
          },
          "frameworkVersion": {
            "type": "string",
            "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "edition": {
            "const": "apple"
          }
        }
      },
      "then": {
        "properties": {
          "targetPlatforms": {
            "items": {
              "enum": [
                "iOS",
                "macOS"
              ]
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "edition": {
            "const": "windows"
          }
        }
      },
      "then": {
        "properties": {
          "targetPlatforms": {
            "items": {
              "const": "Windows"
            }
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
