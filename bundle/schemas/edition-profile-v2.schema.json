{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forsetti.dev/ffae/edition-profile-v2.schema.json",
  "title": "FFAE Edition Profile v2",
  "type": "object",
  "required": [
    "schemaVersion",
    "profileID",
    "profileRevision",
    "edition",
    "frameworkVersion",
    "supportedPlatforms",
    "source",
    "manifestSupport",
    "capabilities",
    "dependencyRules",
    "capabilityMappings",
    "verificationCommands",
    "supportStatus"
  ],
  "properties": {
    "schemaVersion": {
      "const": "2.0"
    },
    "profileID": {
      "type": "string",
      "minLength": 1
    },
    "profileRevision": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    },
    "edition": {
      "enum": [
        "apple",
        "windows"
      ]
    },
    "frameworkVersion": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    },
    "supportedPlatforms": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "iOS",
          "macOS",
          "Windows"
        ]
      }
    },
    "source": {
      "type": "object",
      "required": [
        "repository",
        "revision",
        "policyFiles",
        "policyHash"
      ],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "revision": {
          "type": "string",
          "minLength": 1
        },
        "policyFiles": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "policyHash": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      },
      "additionalProperties": false
    },
    "manifestSupport": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "schemaVersion",
          "templateVersion",
          "schemaPath",
          "status"
        ],
        "properties": {
          "schemaVersion": {
            "type": "string",
            "minLength": 1
          },
          "templateVersion": {
            "type": "string",
            "minLength": 1
          },
          "schemaPath": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "enum": [
              "current",
              "legacy",
              "unsupported"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "dependencyRules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "ruleID",
          "source",
          "allowed",
          "forbidden"
        ],
        "properties": {
          "ruleID": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "type": "string",
            "minLength": 1
          },
          "allowed": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "forbidden": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "capabilityMappings": {
      "type": "string",
      "minLength": 1
    },
    "verificationCommands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "commandID",
          "command",
          "required",
          "appliesWhen"
        ],
        "properties": {
          "commandID": {
            "type": "string"
          },
          "command": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "required": {
            "type": "boolean"
          },
          "appliesWhen": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "supportStatus": {
      "enum": [
        "supported",
        "deprecated",
        "unsupported"
      ]
    }
  },
  "additionalProperties": false
}
