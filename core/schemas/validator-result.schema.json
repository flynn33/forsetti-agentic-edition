{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forsetti.dev/schemas/agentic-edition/validator-result.schema.json",
  "title": "Forsetti Agentic Edition Validator Result",
  "type": "object",
  "required": [
    "status",
    "findings"
  ],
  "properties": {
    "status": {
      "enum": [
        "pass",
        "request_changes",
        "block"
      ]
    },
    "mode": {
      "type": "string"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "rule_id",
          "severity",
          "decision",
          "message"
        ],
        "properties": {
          "rule_id": {
            "type": "string"
          },
          "severity": {
            "enum": [
              "info",
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "decision": {
            "enum": [
              "pass",
              "request_changes",
              "block"
            ]
          },
          "message": {
            "type": "string"
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "remediation": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
